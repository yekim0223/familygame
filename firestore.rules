// MVP 보안 규칙: 인증된 사용자는 가족 데이터 접근 가능
// 클라이언트 코드에서 역할 기반 권한 제어

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 가족 단위 데이터: 인증된 사용자만 접근
    match /families/{familyId}/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /families/{familyId} {
      allow read, write: if request.auth != null;
    }

    // 가족 비밀 코드 조회 테이블 (루트 레벨)
    // - 읽기: 인증된 사용자 (가족 찾기 기능)
    // - 쓰기: 인증된 사용자 (아빠가 코드 등록/변경)
    match /family_codes/{code} {
      allow read, write: if request.auth != null;
    }
  }
}
